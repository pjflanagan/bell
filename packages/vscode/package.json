{
  "name": "bell-vscode",
  "displayName": "Bell Lang: Syntax and UI",
  "description": "A simple script for making http requests",
  "version": "0.1.4",
  "license": "MIT",
  "publisher": "bell",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/pjflanagan/bell.git"
  },
  "homepage": "https://pjflanagan.github.io/bell/",
  "bugs": {
    "url": "https://github.com/pjflanagan/bell/issues"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:bel"
  ],
  "contributes": {
    "commands": [
      {
        "command": "bell.runFile",
        "title": "Bell: Run current file",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .bel",
          "command": "bell.runFile",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "when": "resourceExtname == .bel",
          "command": "bell.runFile",
          "group": "inline"
        }
      ]
    },
    "keybindings": [
      {
        "command": "bell.runFile",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "editorTextFocus && editorLangId == bel"
      }
    ],
    "languages": [
      {
        "id": "bel",
        "aliases": [
          "Bell",
          "bell",
          "bel"
        ],
        "extensions": [
          ".bel"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/bell-light.png",
          "dark": "./icons/bell-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "bel",
        "scopeName": "source.bel",
        "path": "./syntaxes/bel.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Bell",
      "properties": {
        "bell.formatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically format .bel files on save."
        },
        "bell.executablePath": {
          "type": "string",
          "default": "bell",
          "description": "Path to the bell executable. Defaults to 'bell' (assumes it is on PATH)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.110.0",
    "typescript": "^5.3.3"
  }
}
