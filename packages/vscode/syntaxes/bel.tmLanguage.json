{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Bell",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#comment"
		},
		{
			"include": "#support"
		},
		{
			"include": "#variable"
		},
		{
			"include": "#operators"
		}
	],
	"repository": {
		"support": {
			"patterns": [
				{
					"name": "support.function.bel",
					"match": "\\b(log|validate|expect|assert|input|require|run|import|warn)\\b"
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.http.bel",
					"match": "\\b(GET|POST|PUT|DELETE|PATCH|OPTIONS)\\b"
				},
				{
					"name": "keyword.control.bel",
					"match": "\\b(from|as|env)\\b"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.comparison.bel",
					"match": "===|==|!==|!=|<=|>=|<|>"
				},
				{
					"name": "keyword.operator.assignment.bel",
					"match": "="
				},
				{
					"name": "keyword.operator.accessor.bel",
					"match": "\\."
				},
				{
					"name": "keyword.operator.pipe.bel",
					"match": "\\|"
				}
			]
		},
		"comment": {
			"patterns": [
				{
					"name": "comment.block.bel",
					"begin": "###",
					"end": "###"
				},
				{
					"name": "comment.line.number-sign.bel",
					"match": "#.*$"
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.bel",
					"begin": "\"",
					"end": "\""
				},
				{
					"name": "string.quoted.single.bel",
					"begin": "'",
					"end": "'"
				},
				{
					"name": "string.other.url.bel",
					"match": "https?://[^\\s]+"
				},
				{
					"name": "string.other.url.bel",
					"match": "/[a-zA-Z0-9_\\-/]*"
				},
				{
					"name": "constant.numeric.bel",
					"match": "\\b-?[0-9]+(\\.[0-9]+)?\\b"
				},
				{
					"name": "constant.language.boolean.bel",
					"match": "\\b(true|false|null)\\b"
				}
			]
		},
		"variable": {
			"patterns": [
				{
					"name": "variable.language.bel",
					"match": "\\b(url|path|param|header|body|response)\\b"
				},
				{
					"name": "variable.other.bel",
					"match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
				}
			]
		}
	},
	"scopeName": "source.bel"
}
