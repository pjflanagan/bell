{
  "name": "bell-lang",
  "version": "0.0.3",
  "description": "A simple script for making http requests",
  "type": "commonjs",
  "bin": {
    "bell": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build-lexer": "antlr4ts -visitor ./src/grammar/BellLexer.g4",
    "build-parser": "antlr4ts -visitor ./src/grammar/BellParser.g4",
    "build-js": "antlr4 -Dlanguage=Javascript ./src/grammar/BellParser.g4",
    "build": "tsc",
    "main": "npx ts-node ./src/main.ts",
    "test": "tsc && npx mocha \"dist/test/**/*.test.js\"",
    "jest": "jest"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.19.39",
    "antlr4ts-cli": "^0.5.0-alpha.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@types/chai": "^5.2.3",
    "@types/inquirer": "^8.2.12",
    "@types/mocha": "^10.0.10",
    "@types/sinon": "^21.0.1",
    "antlr4": "^4.13.2",
    "antlr4ts": "^0.5.0-alpha.4",
    "axios": "^1.14.0",
    "chai": "^4.5.0",
    "chalk": "4",
    "commander": "^14.0.3",
    "inquirer": "^8.2.7",
    "mocha": "^11.7.5",
    "sinon": "^21.0.3",
    "zod": "^4.3.6"
  }
}
