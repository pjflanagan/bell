url "https://httpbin.org/get?name=Jane+Doe"
GET

# expect checks that an expression is truthy and logs pass or fail
# use assert instead if you want the file to exit on failure
expect response.status === 200
expect response.body.args.name === "Jane Doe"

url "https://httpbin.org/post"
body { "name": "New User" }
POST

expect response.status === 200
