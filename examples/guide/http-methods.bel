url "https://httpbin.org"

# GET — retrieve a resource
path "/get"
GET

# POST — create a resource
path "/post"
body { "name": "Jane" }
POST

# PUT — replace a resource
path "/put"
body { "name": "Jane Doe" }
PUT

# PATCH — update fields on a resource
path "/patch"
body { "name": "Jane D." }
PATCH

# DELETE — remove a resource
path "/delete"
DELETE
