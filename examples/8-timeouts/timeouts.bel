var urlWithLongResponseTime = "https://httpbin.org/delay/3"
var urlToCheckStatus = "https://httpbin.org/get"

url urlWithLongResponseTime

# use timeout to increase or decrease the max wait time for a response
# the default is no timeout (0 = unlimited)
# here we set a 10-second limit
timeout 10 * 1000

POST

# wait 5 seconds before the next request
# useful if the backend has some processing time
wait 5 * 1000

url urlToCheckStatus

GET
